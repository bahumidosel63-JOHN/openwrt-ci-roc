CONFIG_TARGET_qualcommax=y                     # 启用高通AX系列平台架构
CONFIG_TARGET_qualcommax_ipq60xx=y             # 具体选择IPQ60xx芯片组平台
CONFIG_TARGET_MULTI_PROFILE=y                  # 启用多设备编译模式，一次生成多个设备固件
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_alfa-network_ap120c-ax=n      # Alfa Network AP120C-AX (开发板/工业级)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_anysafe_e1=n                  # Anysafe E1 (网络安全设备)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cambiumnetworks_xe3-4=n       # Cambium Networks XE3-4 (企业级AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=n                  # 中国移动 CMIOT AX18 (运营商定制版)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800=n            # GL.iNet GL-AX1800 (开源友好型号)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800=n           # GL.iNet GL-AXT1800 (支持三频)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=n            # 京东云无线宝 RE-CS-02 (需特殊解锁)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=n            # 京东云无线宝 RE-CS-07 (需特殊解锁)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=n            # 京东云无线宝 RE-SS-01 (需特殊解锁)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_kt_ar06-012h=n                # 韩国电信 KT AR06-012H (运营商定制)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_lg_gapd-7500=n                # LG GAPD-7500 (韩国LG U+定制)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v1=n              # Link NN6000 V1 (运营商定制)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y              # Link NN6000 V2 (运营商定制)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7350=n              # Linksys MR7350 (Velop系列)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7500=n              # Linksys MR7500 (Velop系列)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_netgear_wax214=n              # NETGEAR WAX214 (企业级WiFi6 AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_netgear_wax610=n              # NETGEAR WAX610 (企业级WiFi6 AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_netgear_wax610y=n             # NETGEAR WAX610Y (企业级WiFi6 AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=n                 # 360安全路由 V6 (360 V6)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=n                   # Redmi AX5 (红米AX5标准版)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=n           # Redmi AX5 京东云版 (内置128GB存储)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_tplink_eap610od=n             # TP-Link EAP610-Outdoor (室外AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_tplink_eap623od-hd-v1=n       # TP-Link EAP623HD-Outdoor v1 (室外AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_tplink_eap625od-hd-v1=n       # TP-Link EAP625HD-Outdoor v1 (室外AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=n               # 小米 AX1800 (Mi AX1800)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_yuncore_fap650=n              # YunCore FAP650 (企业级AP)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y                       # ZN M2 (兆能)

CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n

CONFIG_ATH11K_MEM_PROFILE_512M=y               # ath11k WiFi驱动内存配置为512MB模式                                                
CONFIG_NSS_FIRMWARE_VERSION_11_4=y             # 使用NSS（网络子系统）固件版本11.4
